# ── Required ──────────────────────────────────────────────────────────────────
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── MCP Server (optional) ─────────────────────────────────────────────────────
# Bearer token for the MCP server. Leave blank for local dev (unauthenticated).
# Set a strong random string for any networked or production deployment.
ARIA_MCP_TOKEN=

# MCP server port (default: 8765)
ARIA_MCP_PORT=8765

# ── Demo mode ─────────────────────────────────────────────────────────────────
# When DEMO_MODE=true in aria_config.yaml, the CRAG prober skips real API calls
# and returns simulated staleness scores. Safe for offline demos.
# To disable demo mode and use live Anthropic API: set demo_mode: false in
# config/aria_config.yaml
