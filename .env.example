# ── Required (pick at least one for live mode) ────────────────────────────────

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq (free tier, no credit card) — https://console.groq.com/keys
# Used as CRAG prober fallback when ANTHROPIC_API_KEY is absent.
# Free tier: 14,400 requests/day, llama-3.1-8b-instant
GROQ_API_KEY=

# ── MCP Server (optional) ─────────────────────────────────────────────────────
# Bearer token for the MCP server. Leave blank for local dev (unauthenticated).
ARIA_MCP_TOKEN=

# MCP server port (default: 8765)
ARIA_MCP_PORT=8765

# ── Demo mode ─────────────────────────────────────────────────────────────────
# When demo_mode: true in aria_config.yaml (the default), ARIA runs fully
# offline with simulated data — no API key needed.
#
# To enable Production Mode:
#   1. Set demo_mode: false in config/aria_config.yaml
#   2. Set GROQ_API_KEY above (free) for live CRAG probes, OR set ANTHROPIC_API_KEY
#   3. Optionally set gold_layer.source: sheets + spreadsheet_id in aria_config.yaml
#      for live Gold data from a public Google Sheet (no auth required).
#
# Free-tier production setup (zero cost):
#   GROQ_API_KEY=gsk_...          # from console.groq.com — free, no card
#   # In aria_config.yaml:
#   # aria.demo_mode: false
#   # gold_layer.source: sheets
#   # gold_layer.spreadsheet_id: YOUR_PUBLIC_SHEET_ID
